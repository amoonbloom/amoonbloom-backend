{
  "name": "amoonis-boutique",
  "version": "1.0.0",
  "description": "Ecommerce backend starter - Express, Prisma, PostgreSQL",
  "main": "server.js",
  "scripts": {
    "start": "prisma migrate deploy && node server.js",
    "seed": "node prisma/seed.js",
    "dev": "nodemon server.js",
    "build": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "e2e": "node scripts/e2e-test.js",
    "kill-port-5000": "powershell -ExecutionPolicy Bypass -File scripts/kill-port-5000.ps1",
    "migrate:fix-p3009": "node scripts/fix-p3009-ecommerce-migration.js"
  },
  "keywords": [
    "express",
    "prisma",
    "postgresql",
    "ecommerce",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.2.0",
    "google-auth-library": "^10.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.13",
    "pg": "^8.17.2",
    "prisma": "^7.3.0",
    "resend": "^6.9.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
